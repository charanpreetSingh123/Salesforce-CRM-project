trigger AutoQualifyLead on My_Led__c (before insert, before update) {

    for (My_Led__c lead : Trigger.new) {

        My_Led__c oldLead = Trigger.isUpdate ? Trigger.oldMap.get(lead.Id) : null;

        if (lead.My_Customer__c != null &&
            (Trigger.isInsert || oldLead.My_Customer__c == null)) {

            lead.Lead_Status__c = 'Qualified';
        }
    }
}
